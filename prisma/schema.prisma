generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Address {
  id           String   @id @default(cuid())
  userId       String   @unique
  zipCode      String
  state        String
  city         String
  neighborhood String
  street       String
  number       String
  complement   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model Configuracao {
  id        String   @id @default(cuid())
  chave     String   @unique
  valor     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contract {
  id            String    @id @default(cuid())
  userId        String    @unique
  fileUrl       String?
  isSigned      Boolean   @default(false)
  signedAt      DateTime?
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?
  updatedAt     DateTime  @updatedAt
  isValidated   Boolean   @default(false)
  validatedAt   DateTime?
  validatedBy   String?
  signedFileUrl String?
  user          User      @relation(fields: [userId], references: [id])
}

model Lesson {
  id        String    @id @default(cuid())
  title     String
  videoUrl  String
  order     Int
  duration  Int
  isFree    Boolean   @default(false)
  slug      String?   @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  unitId    String
  turmaId   String?
  turma     Turma?    @relation(fields: [turmaId], references: [id])
  unit      Unit      @relation(fields: [unitId], references: [id])
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  pin       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Payment {
  id                String        @id @default(cuid())
  userId            String        @unique
  asaasInvoiceId    String        @unique
  value             Float
  dueDate           DateTime
  createdAt         DateTime      @default(now())
  deletedAt         DateTime?
  updatedAt         DateTime      @updatedAt
  status            PaymentStatus @default(PENDING)
  billingType       String?
  pixQrCode         String?
  pixKey            String?
  pixExpirationDate DateTime?
  user              User          @relation(fields: [userId], references: [id])
}

model Prova {
  id                        String           @id @default(cuid())
  titulo                    String
  descricao                 String?
  dataInicioDisponibilidade DateTime
  dataFimDisponibilidade    DateTime
  tempoDuracaoMinutos       Int
  percentualMinimoAprovacao Float            @default(86)
  status                    ProvaStatus      @default(RASCUNHO)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  deletedAt                 DateTime?
  turmaId                   String?
  turma                     Turma?           @relation(fields: [turmaId], references: [id])
  perguntas                 ProvaPergunta[]
  tentativas                ProvaTentativa[]
  alunosAtribuidos          User[]           @relation("ProvaAlunosAtribuidos")

  @@index([status])
  @@index([turmaId])
}

model ProvaAlternativa {
  id        String          @id @default(cuid())
  perguntaId String
  texto     String
  correta   Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  pergunta  ProvaPergunta   @relation(fields: [perguntaId], references: [id], onDelete: Cascade)
  respostas ProvaResposta[]

  @@index([perguntaId])
}

model ProvaEventoFraude {
  id          String         @id @default(cuid())
  tentativaId String
  tipo        String
  descricao   String
  createdAt   DateTime       @default(now())
  tentativa   ProvaTentativa @relation(fields: [tentativaId], references: [id], onDelete: Cascade)

  @@index([tentativaId])
}

model ProvaPergunta {
  id           String             @id @default(cuid())
  provaId      String
  enunciado    String
  valorNota    Float
  ordem        Int
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  alternativas ProvaAlternativa[]
  prova        Prova              @relation(fields: [provaId], references: [id], onDelete: Cascade)
  respostas    ProvaResposta[]

  @@unique([provaId, ordem])
  @@index([provaId])
}

model ProvaResposta {
  id            String            @id @default(cuid())
  tentativaId   String
  perguntaId    String
  alternativaId String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  alternativa   ProvaAlternativa? @relation(fields: [alternativaId], references: [id])
  pergunta      ProvaPergunta     @relation(fields: [perguntaId], references: [id], onDelete: Cascade)
  tentativa     ProvaTentativa    @relation(fields: [tentativaId], references: [id], onDelete: Cascade)

  @@unique([tentativaId, perguntaId])
}

model ProvaTentativa {
  id               String              @id @default(cuid())
  provaId          String
  alunoId          String
  dataInicio       DateTime            @default(now())
  dataFim          DateTime?
  status           TentativaStatus     @default(EM_ANDAMENTO)
  fraudeDetectada  Boolean             @default(false)
  motivoFraude     String?
  notaTotal        Float               @default(0)
  notaObtida       Float               @default(0)
  percentualAcerto Float               @default(0)
  aprovado         Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  eventosfraude    ProvaEventoFraude[]
  respostas        ProvaResposta[]
  aluno            User                @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  prova            Prova               @relation(fields: [provaId], references: [id], onDelete: Cascade)

  @@unique([provaId, alunoId])
  @@index([alunoId])
}

model Certificado {
  id         String   @id @default(cuid())
  alunoId    String
  turmaId    String
  emitidoEm  DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  aluno      User     @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  turma      Turma    @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([alunoId, turmaId])
  @@index([alunoId])
  @@index([turmaId])
}

model Turma {
  id           String         @id @default(cuid())
  nome         String
  descricao    String?
  status       TurmaStatus    @default(ATIVA)
  dataInicio   DateTime
  dataFim      DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?
  certificados Certificado[]
  lessons      Lesson[]
  provas       Prova[]
  units        Unit[]
  alunos       User[]
}

model Unit {
  id          String    @id @default(cuid())
  title       String
  description String?
  order       Int
  slug        String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  turmaId     String?
  lessons     Lesson[]
  turma       Turma?    @relation(fields: [turmaId], references: [id])
}

model User {
  id              String           @id @default(cuid())
  firstName       String
  lastName        String
  email           String           @unique
  password        String
  rg              String?          @unique
  cpf             String           @unique
  birthDate       DateTime
  educationLevel  String
  phone           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  role            String           @default("student")
  asaasCustomerId String?          @unique
  paymentDeferred Boolean          @default(false)
  turmaId         String?
  ativo           Boolean          @default(true)
  lastLoginAt    DateTime?
  sessionVersion Int       @default(1)
  address         Address?
  certificados    Certificado[]
  contract        Contract?
  payment         Payment?
  provaTentativas ProvaTentativa[]
  turma           Turma?           @relation(fields: [turmaId], references: [id])
  provas          Prova[]          @relation("ProvaAlunosAtribuidos")
}

model WebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  eventType String
  payload   Json
  createdAt DateTime @default(now())
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum ProvaStatus {
  RASCUNHO
  ATIVA
  INATIVA
  ENCERRADA
}

enum TentativaStatus {
  EM_ANDAMENTO
  CONCLUIDA
  ENCERRADA_POR_TEMPO
  REPROVADO_POR_FRAUDE
  EXPIRADA
}

enum TurmaStatus {
  ATIVA
  ENCERRADA
}
